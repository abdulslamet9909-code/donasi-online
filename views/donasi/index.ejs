<%- include('../layout/header') %>

<!-- ================= DONASI ================= -->

<section class="form-section">

    <div class="container">

        <div class="row g-5 align-items-start">

    <!-- INFORMASI -->
    <div class="col-lg-5">

        <div class="form-card">

            <span class="badge-soft">
                <i class="bi bi-shield-check me-2"></i>
                Donasi Aman
            </span>

            <h3 class="mt-3 mb-4">
                Informasi Pembayaran
            </h3>

            <div class="mb-4">

                <h5>
                    <i class="bi bi-bank me-2"></i>
                    Transfer Bank
                </h5>

                <div class="border rounded-4 p-3 mb-3">

                    <strong>Bank BRI</strong>

                    <br>

                    1234567890

                    <br>

                    a.n. Panti Asuhan Desa Sumber Asri

                </div>

                <div class="border rounded-4 p-3">

                    <strong>Bank BCA</strong>

                    <br>

                    9876543210

                    <br>

                    a.n. Panti Asuhan Desa Sumber Asri

                </div>

            </div>

            <div class="mb-4">

                <h5>
                    <i class="bi bi-qr-code me-2"></i>
                    Pembayaran QRIS
                </h5>

                <img
                    src="https://api.qrserver.com/v1/create-qr-code/?size=220x220&data=PANTI-SUMBER-ASRI"
                    class="img-fluid rounded shadow">

            </div>

            <div class="alert alert-success">

                <i class="bi bi-clock-history me-2"></i>

                Konfirmasi donasi maksimal
                <strong>1 × 24 Jam.</strong>

            </div>

            <div class="alert alert-light border">

                <i class="bi bi-lock-fill text-success me-2"></i>

                Seluruh data donatur dijaga kerahasiaannya.

            </div>

        </div>

    </div>

    <!-- FORM -->
    <div class="col-lg-7">

        <div class="form-card">

                <div class="form-card">

                    <div class="text-center mb-5">

                        <span class="badge-soft">
                            <i class="bi bi-heart-fill me-2"></i>
                            Form Donasi
                        </span>

                        <h2 class="section-title mt-3">
                            Donasi Online
                        </h2>

                        <p class="text-muted">
                            Isi data berikut untuk melakukan donasi kepada
                            Panti Asuhan Desa Sumber Asri.
                        </p>

                    </div>

                    <form action="/donasi" method="POST" enctype="multipart/form-data">

                        <!-- Nama -->

                        <div class="mb-3">
                            <label class="form-label">
                                Nama Donatur
                            </label>

                            <input
                                type="text"
                                name="nama"
                                class="form-control"
                                placeholder="Masukkan nama lengkap"
                                required>
                        </div>

                        <!-- Email -->

                        <div class="mb-3">
                            <label class="form-label">
                                Email
                            </label>

                            <input
                                type="email"
                                name="email"
                                class="form-control"
                                placeholder="contoh@gmail.com"
                                required>
                        </div>

                        <!-- HP -->

                        <div class="mb-3">
                            <label class="form-label">
                                Nomor HP
                            </label>

                            <input
                                type="text"
                                name="hp"
                                class="form-control"
                                placeholder="08xxxxxxxxxx"
                                required>
                        </div>

                        <!-- Program -->

                        <div class="mb-3">
                            <label class="form-label">
                                Program Donasi
                            </label>

                            <select
                                name="program"
                                class="form-select"
                                required>

                                <option value="">
                                    Pilih Program
                                </option>

                                <option>
                                    Beasiswa Pendidikan
                                </option>

                                <option>
                                    Kesehatan Anak
                                </option>

                                <option>
                                    Kebutuhan Harian
                                </option>

                            </select>

                        </div>

                        <!-- Nominal -->

                        <div class="mb-3">
                            <label class="form-label">
                                Nominal Donasi
                            </label>

                            <input
                                type="number"
                                name="nominal"
                                class="form-control"
                                placeholder="Contoh : 100000"
                                required>
                        </div>

                        <!-- Metode -->

                        <div class="mb-3">

                            <label class="form-label">
                                Metode Pembayaran
                            </label>

                            <select
                                name="metode"
                                class="form-select"
                                required>

                                <option value="">
                                    Pilih Metode
                                </option>

                                <option>
                                    Transfer Bank BRI
                                </option>

                                <option>
                                    Transfer Bank BCA
                                </option>

                                <option>
                                    Transfer Bank Mandiri
                                </option>

                                <option>
                                    QRIS
                                </option>

                            </select>

                        </div>

                        <!-- Upload -->

                        <div class="mb-3">

                            <label class="form-label">
                                Upload Bukti Transfer
                            </label>

                            <input
                                type="file"
                                name="bukti"
                                class="form-control"
                                accept=".jpg,.jpeg,.png,.pdf"
                                required>

                        </div>

                        <!-- Pesan -->

                        <div class="mb-4">

                            <label class="form-label">
                                Pesan / Doa (Opsional)
                            </label>

                            <textarea
                                name="pesan"
                                rows="4"
                                class="form-control"
                                placeholder="Tuliskan doa atau pesan..."></textarea>

                        </div>

                        <button
                            class="btn btn-donasi w-100 py-3">

                            <i class="bi bi-send-fill me-2"></i>

                            Kirim Donasi

                        </button>

                    </form>

                </div>

            </div>

        </div>

    </div>

</section>

<%- include('../layout/footer') %>