<!-- ================= PROGRAM DONASI ================= -->

<section id="program" class="py-5 bg-light">

<div class="container">

    <div class="text-center mb-5">

        <h2 class="fw-bold">
            Program Donasi
        </h2>

        <p class="text-muted">
            Mari bersama membantu melalui program-program berikut.
        </p>

    </div>

    <div class="row g-4">

        <% if(program.length > 0){ %>

            <% program.forEach(item => { %>

                <div class="col-lg-4 col-md-6">

                    <div class="card h-100 shadow-sm border-0">

                        <% if(item.gambar){ %>

                            <img
                                src="/uploads/<%= item.gambar %>"
                                  class="card-img-top"
                                    style="height:220px;object-fit:cover;"
                                        alt="<%= item.nama_program %>">

                                <% } else { %>

                            <img
                                 src="https://via.placeholder.com/600x400?text=Program+Donasi"
                                     class="card-img-top"
                                        style="height:220px;object-fit:cover;"
                                         alt="Program Donasi">

                                    <% } %>

                        <div class="card-body">

                            <h5 class="fw-bold">
                                <%= item.nama_program %>
                            </h5>

                            <p class="text-muted">
                                <%= item.deskripsi %>
                            </p>

                            <small>
                                Target :
                                <strong>
                                    Rp <%= Number(item.target_donasi).toLocaleString('id-ID') %>
                                </strong>
                            </small>

                            <br>

                            <small>
                                Terkumpul :
                                <strong>
                                    Rp <%= Number(item.dana_terkumpul).toLocaleString('id-ID') %>
                                </strong>
                            </small>

                            <%
                                let persen = Math.round((item.dana_terkumpul / item.target_donasi) * 100);
                                if(persen > 100) persen = 100;
                            %>

                            <div class="progress mt-3">

                                <div
                                    class="progress-bar bg-success"
                                    style="width:<%= persen %>%">

                                    <%= persen %>%

                                </div>

                            </div>

                        </div>

                        <div class="card-footer bg-white border-0">

                            <a href="/donasi" class="btn btn-success w-100">

                                Donasi Sekarang

                            </a>

                        </div>

                    </div>

                </div>

            <% }) %>

        <% }else{ %>

            <div class="col-12 text-center">

                <h5>Belum ada program donasi.</h5>

            </div>

        <% } %>

    </div>

</div>

</section>

