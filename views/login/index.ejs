<%- include('../layout/header') %>

<section class="container" style="margin-top:120px; max-width:500px;">

    <div class="card shadow">

        <div class="card-body">

            <h3 class="text-center mb-4">
                Login Admin
            </h3>

            <% if(error){ %>

                <div class="alert alert-danger">

                    <%= error %>

                </div>

            <% } %>

            <form action="/login" method="POST">

                <div class="mb-3">

                    <label class="form-label">
                        Username
                    </label>

                    <input
                        type="text"
                        name="username"
                        class="form-control"
                        required>

                </div>

                <div class="mb-3">

                    <label class="form-label">
                        Password
                    </label>

                    <input
                        type="password"
                        name="password"
                        class="form-control"
                        required>

                </div>

                <button
                    type="submit"
                    class="btn btn-primary w-100">

                    Login

                </button>

            </form>

        </div>

    </div>

</section>

<%- include('../layout/footer') %>