<%- include('../layout/header') %>

<section class="container py-5" style="margin-top:120px;">

    <div class="row justify-content-center">

        <div class="col-lg-6">

            <div class="card shadow">

                <div class="card-header bg-primary text-white">

                    <h4 class="mb-0">
                        Edit Status Donasi
                    </h4>

                </div>

                <div class="card-body">

                    <form action="/admin/edit/<%= donasi.id %>" method="POST">

                        <div class="mb-3">

                            <label class="form-label">
                                Nama Donatur
                            </label>

                            <input
                                type="text"
                                class="form-control"
                                value="<%= donasi.nama %>"
                                readonly>

                        </div>

                        <div class="mb-3">

                            <label class="form-label">
                                Program Donasi
                            </label>

                            <input
                                type="text"
                                class="form-control"
                                value="<%= donasi.program %>"
                                readonly>

                        </div>

                        <div class="mb-3">

                            <label class="form-label">
                                Nominal Donasi
                            </label>

                            <input
                                type="text"
                                class="form-control"
                                value="Rp <%= Number(donasi.nominal).toLocaleString('id-ID') %>"
                                readonly>

                        </div>

                        <div class="mb-4">

                            <label class="form-label">
                                Status Donasi
                            </label>

                            <select
                                name="status"
                                class="form-select"
                                required>

                                <option value="Menunggu"
                                    <%= donasi.status=="Menunggu" ? "selected" : "" %>>
                                    Menunggu
                                </option>

                                <option value="Diterima"
                                    <%= donasi.status=="Diterima" ? "selected" : "" %>>
                                    Diterima
                                </option>

                                <option value="Ditolak"
                                    <%= donasi.status=="Ditolak" ? "selected" : "" %>>
                                    Ditolak
                                </option>

                            </select>

                        </div>

                        <div class="d-flex justify-content-between">

                            <a href="/admin" class="btn btn-secondary">

                                <i class="bi bi-arrow-left"></i>

                                Kembali

                            </a>

                            <button
                                type="submit"
                                class="btn btn-success">

                                <i class="bi bi-check-circle"></i>

                                Simpan Perubahan

                            </button>

                        </div>

                    </form>

                </div>

            </div>

        </div>

    </div>

</section>

<%- include('../layout/footer') %>