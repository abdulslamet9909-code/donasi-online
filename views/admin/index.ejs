<%- include('../layout/header') %>

<section class="container py-5" style="margin-top:120px;">

    <div class="d-flex justify-content-between align-items-center mb-4">

    <div>
        <h2 class="fw-bold">
            Dashboard Admin
        </h2>

        <p class="text-muted mb-0">
            Data seluruh donasi yang masuk.
        </p>
    </div>

    <div class="d-flex gap-2">

    <a href="/program"
       class="btn btn-primary">

        <i class="bi bi-folder"></i>
        Kelola Program

    </a>

    <a href="/laporan/pdf"
       target="_blank"
       class="btn btn-danger">

        <i class="bi bi-file-earmark-pdf"></i>
        Export PDF

    </a>

    <a href="/laporan/excel"
       class="btn btn-success">

        <i class="bi bi-file-earmark-excel"></i>
        Export Excel

    </a>

    <a href="/logout"
       class="btn btn-secondary">

        <i class="bi bi-box-arrow-right"></i>
        Logout

    </a>

</div>

</div>

    <div class="card shadow-sm">

        <div class="card-body">

            <div class="table-responsive">

                <table class="table table-bordered table-hover align-middle">

                    <thead class="table-dark text-center">

                        <tr>

                            <th>No</th>
                            <th>Nama</th>
                            <th>Program</th>
                            <th>Nominal</th>
                            <th>Status</th>
                            <th>Bukti</th>
                            <th>Tanggal</th>
                            <th>Aksi</th>

                        </tr>

                    </thead>

                    <tbody>

                    <% if(donasi.length > 0){ %>

                        <% donasi.forEach((item,index)=>{ %>

                        <tr>

                            <td class="text-center">
                                <%= index+1 %>
                            </td>

                            <td>
                                <strong><%= item.nama %></strong><br>
                                <small class="text-muted">
                                    <%= item.email %><br>
                                    <%= item.hp %>
                                </small>
                            </td>

                            <td>
                                <%= item.program %>
                            </td>

                            <td>
                                <strong>
                                    Rp <%= Number(item.nominal).toLocaleString('id-ID') %>
                                </strong>
                            </td>

                            <td class="text-center">

                                <% if(item.status=="Menunggu"){ %>

                                    <span class="badge bg-warning text-dark">
                                        Menunggu
                                    </span>

                                <% }else if(item.status=="Diterima"){ %>

                                    <span class="badge bg-success">
                                        Diterima
                                    </span>

                                <% }else{ %>

                                    <span class="badge bg-danger">
                                        Ditolak
                                    </span>

                                <% } %>

                            </td>

                            <td class="text-center">

                                <% if(item.bukti){ %>

                                    <a href="/uploads/<%= item.bukti %>"
                                       target="_blank"
                                       class="btn btn-success btn-sm">

                                        <i class="bi bi-image"></i>
                                        Lihat

                                    </a>

                                <% }else{ %>

                                    -

                                <% } %>

                            </td>

                            <td>
                                <%= item.tanggal %>
                            </td>

                            <td class="text-center">

                                <a href="/admin/edit/<%= item.id %>"
                                    class="btn btn-primary btn-sm mb-1">

                                        <i class="bi bi-pencil-square"></i>

                                        Edit

                                         </a>

                                        <a href="/admin/hapus/<%= item.id %>"
                                            class="btn btn-danger btn-sm"
                                            onclick="return confirm('Yakin ingin menghapus donasi ini?')">

                                        <i class="bi bi-trash"></i>

                                             Hapus

                                    </a>

                            </td>

                        </tr>

                        <% }) %>

                    <% }else{ %>

                        <tr>

                            <td colspan="8" class="text-center">

                                Belum ada data donasi.

                            </td>

                        </tr>

                    <% } %>

                    </tbody>

                </table>

            </div>

        </div>

    </div>

</section>

<%- include('../layout/footer') %>